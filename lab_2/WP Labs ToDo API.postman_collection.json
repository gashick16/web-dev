{
  "info": {
    "_postman_id": "b4f5e55f-5f1f-4dbc-ae2a-15d3cd6ef3a2",
    "name": "WP Labs ToDo API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "25191569"
  },
  "item": [
    {
      "name": "All todos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Пагинация работает\", () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('data');",
              "  pm.expect(json).to.have.property('meta');",
              "  pm.expect(json.meta.totalPages).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:4200/todo?page=1&limit=10",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "4200",
          "path": [
            "todo"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create todo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"201 Created\", () => {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Todo создан\", () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json.title).to.eql('Купить молоко');",
              "  pm.expect(json.status).to.eql('pending');",
              "  pm.environment.set('todo_id', json.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Купить молоко\",\n  \"description\": \"Завтра\",\n  \"status\": \"pending\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:4200/todo",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "4200",
          "path": [
            "todo"
          ]
        }
      },
      "response": []
    },
    {
      "name": "One todo",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Если todo_id пустой, пропусти",
              "if (!pm.environment.get('todo_id')) {",
              "  postman.setNextRequest('2. POST /todo (создать)');",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Todo найден\", () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.id).to.eql(pm.environment.get('todo_id'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:4200/todo/{{todo_id}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "4200",
          "path": [
            "todo",
            "{{todo_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update todo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"200 OK\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Статус changed\", () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql('completed');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"completed\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:4200/todo/{{todo_id}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "4200",
          "path": [
            "todo",
            "{{todo_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Soft delete todo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"204 No Content\", () => {",
              "  pm.response.to.have.status(204);",
              "  pm.expect(pm.response.code).to.eql(204);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://localhost:4200/todo/{{todo_id}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "4200",
          "path": [
            "todo",
            "{{todo_id}}"
          ]
        }
      },
      "response": []
    },
